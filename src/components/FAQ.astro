<section class="space-y-4">
  <h2 class="text-4xl font-bold">
    FAQ
  </h2>

  <div
    x-data="{ open: false }"
    class="rounded-2xl border bg-white p-6 shadow-sm"
  >
    <button
      @click="open = !open"
      class="flex w-full items-center justify-between text-left font-semibold"
    >
      <span>Apakah tersedia pengiriman paket?</span>

      <span x-text="open ? '-' : '+'"></span>
    </button>

    <div
      x-show="open"
      x-transition
      class="mt-4 text-gray-600"
    >
      Ya, PO Bus Sinabung Jaya melayani pengiriman paket ke berbagai kota tujuan.
    </div>
  </div>
</section>